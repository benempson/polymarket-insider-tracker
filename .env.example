# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=polymarket_tracker
POSTGRES_USER=tracker
POSTGRES_PASSWORD=dev_password

# Constructed database URL (for application use)
DATABASE_URL=postgresql://tracker:dev_password@localhost:5432/polymarket_tracker

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Optional: Development tool ports
ADMINER_PORT=8080
REDIS_INSIGHT_PORT=5540

# Polygon RPC Configuration (at least one POLYGON_RPC_URL_* is required)
# Provider names are derived from the suffix (e.g. _INFURA -> "infura")
#POLYGON_RPC_URL_INFURA=https://polygon-mainnet.infura.io/v3/YOUR_KEY
#POLYGON_RPC_URL_ALCHEMY=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
POLYGON_RPC_URL_PUBLICNODE=https://polygon-bor.publicnode.com

# Polymarket API Configuration
POLYMARKET_WS_URL=wss://ws-live-data.polymarket.com

# Alert Webhooks (optional)
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email Error Notifications (optional)
#EMAIL_SMTP_HOST=smtp.gmail.com
#EMAIL_SMTP_PORT=587
#EMAIL_USERNAME=alerts@example.com
#EMAIL_PASSWORD=app-password-here
#EMAIL_FROM=alerts@example.com
#EMAIL_TO=ops-team@example.com,dev@example.com
#EMAIL_USE_TLS=true
#EMAIL_COOLDOWN_MINUTES=30

# Application
LOG_LEVEL=INFO
HEALTH_PORT=8080
DRY_RUN=false

# Heartbeat notifications (0 to disable)
HEARTBEAT_INTERVAL_MINUTES=240
HEARTBEAT_START_HOUR=9
HEARTBEAT_END_HOUR=21

# Deployment (used by scripts/deploy.ps1 — not needed by the application)
DEPLOY_VM_HOST=
DEPLOY_VM_PORT=
DEPLOY_VM_USER=
DEPLOY_VM_APP_DIR=
GHCR_USER=
GHCR_PAT=
REDIS_CONTAINER_NAME=